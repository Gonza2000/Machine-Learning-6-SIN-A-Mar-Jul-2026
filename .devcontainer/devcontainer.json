{
    "name": "ML Workshop - Work Environment",
    "build":{
        "dockerfile":"Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "ms-toolsai.jupyter-renderers",
                "charliermarsh.ruff",
                "ms-azuretools.vscode-containers"
            ],
            "settings":{
                "python.defaultInterpreterPath": "/app/.venv/bin/python",
                "jupyter.notebookFileRoot": "${workspaceFolder}"
            }
        }
    },
    "postCreateCommand": "echo 'source /app/.venv/bin/activate' >> ~/.bashrc && /app/.venv/bin/python -m ipykernel install --user --name gonzalo_env --display-name 'Entorno de Gonzalo (.venv)'"
}