{
    "name": "Ml WorkShop 2 - Work Environment",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "ms-toolsai.jupyter-renderers",
                "Charliemarsh.ruff",
                "ms-azuretools.vscode-containers"
            ],
            "settings": {
                // Ruta absoluta al python del entorno virtual
                "python.defaultInterpreterPath": "/workspaces/Machine-Learning-6-SIN-A-Mar-Jul-2026/.venv/bin/python",
                "jupyter.notebookFileRoot": "${workspaceFolder}"
            }
        }
    },
    // Comando para que la terminal se abra con el venv activo
    "postCreateCommand": "echo 'source .venv/bin/activate' >> ~/.bashrc"
}
