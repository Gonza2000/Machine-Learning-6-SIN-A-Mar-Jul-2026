{
    "name": "ML Workshop - Work Environment",
    "build":{
        "dockerfile":"Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "ms-toolsai.jupyter-renderers",
                "charliermarsh.ruff",
                "ms-azuretools.vscode-containers"
            ],
            "settings":{
                "python.defaultInterpreterPath":"/app/Gonzalo/bin/python",
                "jupyter.notebookFileRoot":"${workspaceFolder}"
            }
        }
    },
    "postCreateCommand": "echo 'source /app/Gonzalo/bin/activate' >> ~/.bashrc && /app/Gonzalo/bin/python -m ipykernel install --user --name Gonzalo --display-name 'Gonzalo'"
}